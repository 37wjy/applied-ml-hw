   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "noise=[100,150, 200, 400, 600, 1000]\n",
    "sample=[10,20, 30, 30, 40]\n",
    "\n",
    "\n",
    "def main():\n",
    "    plt.style.use('seaborn-whitegrid')\n",
    "    \n",
    "    for i in noise :\n",
    "        noise_scale = i \n",
    "        for j in sample:\n",
    "            x1=[0]*j\n",
    "            y1=[0]*j\n",
    "            number_of_samples = j\n",
    "            x=25*(np.random.rand(number_of_samples, 1) - 0.8)\n",
    "            y=5 * x + 20 * x**2 + 1 * x**3 + noise_scale*np.random.randn(number_of_samples, 1) \n",
    "            for k in range(j):\n",
    "                x1[k]=x[k][0]\n",
    "                y1[k]=y[k][0]\n",
    "            z=np.polyfit(x1,y1,5)\n",
    "            x1.sort();\n",
    "            z=np.polyval(z,x1)\n",
    "            plt.title(\"noise : \"+str(i)+\" samples : \"+str(j))\n",
    "            plt.xlabel('x')\n",
    "            plt.ylabel('f(x)')\n",
    "            plt.plot(x,y,'bo')\n",
    "            plt.plot(x1,z,'r')\n",
    "            plt.show()\n",
    "    \n",
    "main()\n",
    "\n"
   ]
  }
 ],
